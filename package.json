{
  "name": "multiclaw",
  "version": "1.0.0",
  "description": "A lightweight multi-agent collaboration layer built on OpenClaw with Feishu/Lark integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "verify": "ts-node scripts/verify/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "openclaw",

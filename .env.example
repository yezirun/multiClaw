# OpenClaw API Configuration
OPENCLAW_API_KEY=<OPENCLAW_API_KEY>
OPENCLAW_BASE_URL=https://api.openclaw.ai

# ===========================================
# Feishu / Lark Integration - 8-Bot Configuration
# ===========================================

# Chat ID for group discussions
FEISHU_CHAT_ID=<FEISHU_CHAT_ID>

# Single Bot Mode (for backward compatibility)
# Set to true to use one bot for all agents
# Set to false to use individual bot per agent (recommended for 8-agent group chat)
FEISHU_SINGLE_BOT_MODE=false

# Single Bot Credentials (used when FEISHU_SINGLE_BOT_MODE=true)
FEISHU_APP_ID=<FEISHU_APP_ID>
FEISHU_APP_SECRET=<FEISHU_APP_SECRET>

# ===========================================
# Individual Bot Credentials for 8-Agent Group Chat
# Each agent has its own bot identity
# ===========================================

# Agent 1 - CTO (Master Agent)
FEISHU_AGENT1_APP_ID=<FEISHU_AGENT1_APP_ID>
FEISHU_AGENT1_APP_SECRET=<FEISHU_AGENT1_APP_SECRET>

# Agent 2 - Product Owner
FEISHU_AGENT2_APP_ID=<FEISHU_AGENT2_APP_ID>
FEISHU_AGENT2_APP_SECRET=<FEISHU_AGENT2_APP_SECRET>

# Agent 3 - Architect
FEISHU_AGENT3_APP_ID=<FEISHU_AGENT3_APP_ID>
FEISHU_AGENT3_APP_SECRET=<FEISHU_AGENT3_APP_SECRET>

# Agent 4 - Backend
FEISHU_AGENT4_APP_ID=<FEISHU_AGENT4_APP_ID>
FEISHU_AGENT4_APP_SECRET=<FEISHU_AGENT4_APP_SECRET>

# Agent 5 - Frontend
FEISHU_AGENT5_APP_ID=<FEISHU_AGENT5_APP_ID>
FEISHU_AGENT5_APP_SECRET=<FEISHU_AGENT5_APP_SECRET>

# Agent 6 - Implementation
FEISHU_AGENT6_APP_ID=<FEISHU_AGENT6_APP_ID>
FEISHU_AGENT6_APP_SECRET=<FEISHU_AGENT6_APP_SECRET>

# Agent 7 - QA
FEISHU_AGENT7_APP_ID=<FEISHU_AGENT7_APP_ID>
FEISHU_AGENT7_APP_SECRET=<FEISHU_AGENT7_APP_SECRET>

# Agent 8 - DevOps
FEISHU_AGENT8_APP_ID=<FEISHU_AGENT8_APP_ID>
FEISHU_AGENT8_APP_SECRET=<FEISHU_AGENT8_APP_SECRET>

# ===========================================
# Runtime Configuration
# ===========================================

NODE_ENV=development
LOG_LEVEL=info

# Optional: Custom Configuration
# MAX_MESSAGES=50
# SUMMARIZE_THRESHOLD=10
# ENABLE_WORK_SUMMARY=true

# ===========================================
# Visible Discussion Configuration
# ===========================================

# Enable visible group chat discussions
VISIBLE_DISCUSSION_ENABLED=false

# Canary chat IDs for testing (comma-separated)
VISIBLE_DISCUSSION_CANARY_CHAT_IDS=<CANARY_CHAT_IDS>

# Trigger prefix for discussion
VISIBLE_DISCUSSION_TRIGGER_PREFIX=[swarm]

# Require @mention to trigger
VISIBLE_DISCUSSION_MENTION_REQUIRED=true